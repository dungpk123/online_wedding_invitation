<!-- ===== THANK YOU ===== -->
<section class="thank-you fade reveal fx-fade-up reveal-stagger">
    <div class="thank-you-content">
        <h2 class="script">Cảm ơn!</h2>
        <p>Sự hiện diện của quý vị là niềm vui và vinh hạnh cho gia đình chúng tôi.</p>
        <p><strong>Chân thành cảm ơn!</strong></p>
    </div>
</section>

<!-- Modal -->
<div class="modal" id="videoModal" role="dialog" aria-modal="true" aria-label="Video kỷ niệm">
    <div class="modal-content">
        <button id="closeModal" type="button" aria-label="Đóng">&times;</button>
        <video controls>
            <source src="sample.mp4" type="video/mp4">
        </video>
    </div>
</div>
